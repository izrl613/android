{
  "files.watcherExclude": {
    "**/node_modules/**": true,
    "**/.git/**": true,
    "**/.firebase/**": true,
    "**/dist/**": true,
    "**/build/**": true,
    "**/.next/**": true,
    "**/.cache/**": true,
    "**/coverage/**": true
  },
  "search.exclude": {
    "**/node_modules": true,
    "**/.git": true,
    "**/.firebase": true,
    "**/dist": true,
    "**/build": true,
    "**/.next": true,
    "**/.cache": true,
    "**/coverage": true
  },
  "typescript.tsserver.maxTsServerMemory": 1024,
  "workbench.colorCustomizations": {
    "statusBar.background": "#0000FF",
    "statusBar.foreground": "#FFFFFF",
    "statusBar.border": "#0000FF",
    "statusBarItem.hoverBackground": "#0000CC",
    "statusBarItem.remoteBackground": "#0000FF",
    "statusBarItem.remoteForeground": "#FFFFFF",
    "titleBar.activeBackground": "#0000FF",
    "titleBar.activeForeground": "#FFFFFF",
    "titleBar.inactiveBackground": "#0000AA",
    "titleBar.inactiveForeground": "#CCCCCC"
  }
}
