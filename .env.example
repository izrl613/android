# ARCHITECT_AI_BASE_URL: Base URL of the local Ollama instance serving gemma4:e2b.
# On the Android emulator, 10.0.2.2 maps to the host machine's loopback (127.0.0.1).
# On a physical device connected to the same Wi-Fi, use the host machine's LAN IP.
# No data leaves the device — processing is fully offline.
ARCHITECT_AI_BASE_URL=http://10.0.2.2:11434
ARCHITECT_AI_MODEL=gemma4:e2b
